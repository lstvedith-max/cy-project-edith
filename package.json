{
  "name": "cy-project-edith-promax",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:smoke": "cypress run --spec \"cypress/e2e/0-smoke/**/*\"",
    "cy:modules": "cypress run --spec \"cypress/e2e/1-modules/**/*\"",
    "cy:regression": "cypress run --spec \"cypress/e2e/2-regression/**/*\"",
    "test:ci:smoke": "npm run cy:smoke",
    "test:ci:modules": "npm run cy:modules",
    "test:ci:regression": "npm run cy:regression",
    "report:merge": "mochawesome-merge reports/mocha/*.json > reports/mochawesome.json",
    "report:html": "marge reports/mochawesome.json -f report -o reports/html",
    "test:ci": "npm run test:ci:smoke"
  },
