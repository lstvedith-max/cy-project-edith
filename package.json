    "cypress-file-upload": "^5.0.8",
    "cypress-mochawesome-reporter": "^3.8.4",
    "cypress-real-events": "^1.15.0",
    "cypress-xpath": "^2.0.1",
    "dotenv": "^17.3.1"
  }
